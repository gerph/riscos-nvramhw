/*******************************************************************
 * File:        os
 * Purpose:     OS interface functions for NVRAMHW module
 *              Vector claim/release operations
 * Author:      Charles Ferguson
 ******************************************************************/

#include "kernel.h"
#include "swis.h"
#include "os.h"

#include "riscos/Vectors.h"

/* Forward declaration of vector entry point generated by CMHG */
extern void NVRAMV_Entry(void);


/***************************************************************************
 * Function:     nvramv_claim
 * Description:  Claim the NVRAMV vector
 * Parameters:   pw = private word for module
 * On exit:      Returns NULL on success, error block on failure
 **************************************************************************/
_kernel_oserror *nvramv_claim(void *pw)
{
    _kernel_oserror *err;
    
    err = _swix(OS_Claim, _INR(0,2),
                NVRAMV, NVRAMV_Entry, pw);
    
    return err;
}


/***************************************************************************
 * Function:     nvramv_release
 * Description:  Release the NVRAMV vector
 * Parameters:   pw = private word for module
 * On exit:      Returns NULL on success, error block on failure
 **************************************************************************/
_kernel_oserror *nvramv_release(void *pw)
{
    _kernel_oserror *err;
    
    err = _swix(OS_Release, _INR(0,2),
                NVRAMV, NVRAMV_Entry, pw);
    
    return err;
}
